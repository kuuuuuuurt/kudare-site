{
  // Hide folders you should never edit by hand from the file explorer.
  // - dist/  is the build output, regenerated by `npm run build`.
  // - node_modules/ is installed packages, regenerated by `npm install`.
  // - .astro/ is Astro's internal cache.
  // You can always un-hide one in the explorer's "..." menu if you need to peek.
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "node_modules": true,
    "dist": true,
    ".astro": true
  },

  // The prototype file (design-reference/index.html) intentionally embeds
  // JSX inside <script type="text/babel"> tags. The HTML linter doesn't
  // understand JSX and would flag it as errors. Turn that one validator off
  // so the prototype stops showing a red error count.
  "html.validate.scripts": false,

  // Search shouldn't dredge up build output or vendored code.
  "search.exclude": {
    "dist": true,
    "node_modules": true,
    ".astro": true
  }
}
