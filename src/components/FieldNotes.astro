---
import SectionMark from "./SectionMark.astro";
import { getLatestPosts, PUBLICATION_URL } from "../lib/substack";

const posts = await getLatestPosts(3);

const monthYear = new Intl.DateTimeFormat("en-US", { month: "short", year: "numeric" });
const fmtDate = (d: Date) => monthYear.format(d).toUpperCase().replace(" ", " · ");
---
<section class="section" id="notes" style="background: var(--paper-2)">
  <div class="wrap">
    <SectionMark folio="04" label="Perspicacity" />
    <div class="section__head">
      <div>
        <span class="kick">Yes, it's a Substack.</span>
        <h2>Our POV, in writing.</h2>
      </div>
      <a
        class="kick foot__sup"
        style="white-space: nowrap"
        href={PUBLICATION_URL}
        target="_blank"
        rel="noopener noreferrer"
      >Read more →</a>
    </div>
    <div class="notes">
      {posts.map((nt) => (
        <a class="note-card" href={nt.url} target="_blank" rel="noopener noreferrer">
          <span class="note-card__fig">{fmtDate(nt.date)}</span>
          <h3 class="note-card__title">{nt.title}</h3>
          <p>{nt.excerpt}</p>
          <div class="note-card__foot">
            <span>{nt.readMinutes} min read</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* Cards are now anchors — kill the default link decoration without changing
     the rest of the .note-card styling (which already does a pointer cursor
     and hover background lift). */
  .note-card {
    color: inherit;
    text-decoration: none;
  }
  /* The "Read more →" link in the section header inherits .kick but needs
     anchor cleanup. */
  a.kick {
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  a.kick:hover { color: var(--ink); }
</style>
