# ----------------------------------------------------------------------
# Custom 404 page
# ----------------------------------------------------------------------
# Tell Apache to serve our designed 404 for any unmatched route instead
# of its default "Not Found" page.
ErrorDocument 404 /404.html


# ----------------------------------------------------------------------
# Cache headers
# ----------------------------------------------------------------------
# Astro emits CSS/JS into /_astro/ with content hashes baked into the
# filename (e.g. hoisted.AbCd1234.js). Whenever the source changes, the
# filename changes, which busts client caches automatically. That makes
# it safe to cache those assets aggressively.
#
# Brand-mark SVGs and any other static asset don't fingerprint, so they
# get a moderate cache. HTML gets a short cache so content updates show
# up quickly.
<IfModule mod_headers.c>
  # Fingerprinted bundles — cache forever
  <FilesMatch "\.(css|js|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Public assets without fingerprinting — 30 days
  <FilesMatch "\.(jpg|jpeg|png|svg|webp|ico|pdf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML — short cache so edits propagate within minutes
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>
